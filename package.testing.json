{
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:components": "vitest run tests/components",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:unit:coverage": "vitest run tests/unit --coverage",
    "test:components:coverage": "vitest run tests/components --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:ui": "playwright test tests/e2e --ui",
    "test:e2e:debug": "playwright test tests/e2e --debug",
    "test:a11y": "vitest run tests/a11y",
    "test:performance": "lighthouse-ci autorun",
    "test:all": "npm run test:unit && npm run test:components && npm run test:integration && npm run test:e2e",
    "test:ci": "npm run test:coverage && npm run test:e2e",
    "test:setup": "playwright install"
  }
}
